<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_blocked_domain_bg"
    android:elevation="12dp"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/time_exhausted_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/time_exhausted_title"
        android:textColor="#1A1A1A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/time_exhausted_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/time_exhausted_body"
        android:textColor="#333333"
        android:textSize="14sp" />

    <Button
        android:id="@+id/time_exhausted_call"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="44dp"
        android:text="@string/time_exhausted_call"
        android:textColor="@color/timekpr_primary"
        android:visibility="gone" />
</LinearLayout>
