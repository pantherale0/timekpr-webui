<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Parental Access"
        android:textColor="#1A1A1A"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Enter the 6-digit parental access code generated on the parent's dashboard to reset this device's screen lock PIN."
        android:textColor="#555555"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/pinEntryField"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:hint="000 000"
        android:inputType="number"
        android:maxLength="6"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:background="@null"
        android:letterSpacing="0.2" />

    <View
        android:layout_width="220dp"
        android:layout_height="2dp"
        android:background="#CCCCCC"
        android:layout_marginTop="4dp" />

    <!-- Simple grid for keypad to guarantee reliable lock screen entry -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btn1" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="1" android:textSize="20sp" android:layout_margin="8dp" />
            <Button android:id="@+id/btn2" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="2" android:textSize="20sp" android:layout_margin="8dp" />
            <Button android:id="@+id/btn3" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="3" android:textSize="20sp" android:layout_margin="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btn4" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="4" android:textSize="20sp" android:layout_margin="8dp" />
            <Button android:id="@+id/btn5" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="5" android:textSize="20sp" android:layout_margin="8dp" />
            <Button android:id="@+id/btn6" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="6" android:textSize="20sp" android:layout_margin="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btn7" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="7" android:textSize="20sp" android:layout_margin="8dp" />
            <Button android:id="@+id/btn8" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="8" android:textSize="20sp" android:layout_margin="8dp" />
            <Button android:id="@+id/btn9" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="9" android:textSize="20sp" android:layout_margin="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnDel" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="⌫" android:textSize="18sp" android:layout_margin="8dp" />
            <Button android:id="@+id/btn0" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="0" android:textSize="20sp" android:layout_margin="8dp" />
            <Button android:id="@+id/btnOk" style="?android:attr/buttonStyle" android:layout_width="72dp" android:layout_height="72dp" android:text="OK" android:textSize="18sp" android:layout_margin="8dp" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnCancel"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Cancel"
        android:textColor="#888888" />
</LinearLayout>
