<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:background="@drawable/overlay_blocked_domain_bg"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/blocked_domain_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/domain_block_overlay_title"
        android:textColor="#1A1A1A"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blocked_domain_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#333333"
        android:textSize="14sp" />

    <Button
        android:id="@+id/blocked_domain_dismiss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:background="@android:color/transparent"
        android:text="@string/domain_block_dismiss"
        android:textColor="@color/timekpr_primary" />
</LinearLayout>
