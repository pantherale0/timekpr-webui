<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:background="@drawable/overlay_blocked_domain_bg"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/blocked_domain_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/domain_block_overlay_title"
        android:textColor="#1A1A1A"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blocked_domain_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#333333"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/blocked_domain_request_access"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:minHeight="44dp"
            android:text="@string/domain_block_request_access"
            android:textColor="@color/timekpr_primary"
            android:visibility="gone" />

        <Button
            android:id="@+id/blocked_domain_dismiss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:minHeight="44dp"
            android:text="@string/domain_block_dismiss"
            android:textColor="@color/timekpr_primary" />
    </LinearLayout>
</LinearLayout>
