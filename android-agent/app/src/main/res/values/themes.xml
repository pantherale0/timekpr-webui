<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GuardianAgent" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/guardian_primary</item>
        <item name="colorOnPrimary">@color/guardian_on_primary</item>
        <item name="colorPrimaryContainer">@color/guardian_surface_container</item>
        <item name="colorOnPrimaryContainer">@color/guardian_text_primary</item>
        <item name="colorSecondary">@color/guardian_primary</item>
        <item name="colorOnSecondary">@color/guardian_on_primary</item>
        <item name="colorSurface">@color/guardian_canvas</item>
        <item name="colorOnSurface">@color/guardian_text_primary</item>
        <item name="android:colorBackground">@color/guardian_canvas</item>
        <item name="android:statusBarColor">@color/guardian_canvas</item>
        <item name="android:navigationBarColor">@color/guardian_canvas</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Widget.Guardian.WizardButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/guardian_primary</item>
    </style>
</resources>
