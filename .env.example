# Copy to .env (setup-dev.sh does this automatically) and adjust as needed.
AGENT_TOKEN=replace-with-a-long-random-bootstrap-token
TZ=UTC
TIMEKPR_SERVER_VERSION=v0.0.0-dev
DEBUG=1
DATABASE_URL=sqlite:///timekpr.db
TIMEKPR_ENABLE_BACKGROUND_TASKS=1
TIMEKPR_AGENT_WS_URL=ws://127.0.0.1:5000/ws
# GitHub owner/repo used for agent release assets (defaults to pantherale0/timekpr-webui):
# TIMEKPR_GITHUB_RELEASE_REPO=pantherale0/timekpr-webui
# Release asset cache TTL in seconds for update availability checks (default 120):
# TIMEKPR_RELEASE_CACHE_TTL_SECONDS=120
# Optional Android FCM (needed for push wake on real devices):
# FCM_SERVER_KEY=
# FIREBASE_CREDENTIALS_JSON=
# Optional pairing firewall:
# REGISTRATION_TOKEN=
