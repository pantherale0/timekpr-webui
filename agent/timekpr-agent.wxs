<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="TimeKpr Agent" Language="1033" Version="$(var.Version)" Manufacturer="TimeKpr" UpgradeCode="db7b7bf0-3cb8-4bba-9572-cf5273ba9b99">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <!-- Public properties that can be passed via command line or modified in GUI -->
        <Property Id="SERVER_URL" Value="ws://localhost:5000/ws" Secure="yes" />
        <Property Id="REGISTRATION_TOKEN" Secure="yes" />

        <!-- Custom Actions to write config.json using CustomActionData (since write runs deferred as LocalSystem) -->
        <CustomAction Id="SetWriteConfigActionData" Property="WriteConfigAction" Value="[SERVER_URL]|||[REGISTRATION_TOKEN]" />
        
        <CustomAction Id="WriteConfigAction"
                      Directory="INSTALLFOLDER"
                      ExeCommand="powershell.exe -ExecutionPolicy Bypass -Command &quot;$parts = '[CustomActionData]' -split '\|\|\|'; $server = $parts[0]; $token = if ($parts.Length -gt 1) { $parts[1] } else { '' }; New-Item -ItemType Directory -Force -Path 'C:\ProgramData\TimeKpr'; @{ server_url = $server; registration_token = $token } | ConvertTo-Json | Out-File -FilePath 'C:\ProgramData\TimeKpr\config.json' -Encoding utf8&quot;"
                      Execute="deferred"
                      Impersonate="no"
                      Return="check" />

        <InstallExecuteSequence>
            <Custom Action="SetWriteConfigActionData" Before="WriteConfigAction">NOT Installed</Custom>
            <Custom Action="WriteConfigAction" Before="StartServices">NOT Installed</Custom>
        </InstallExecuteSequence>

        <!-- Configuration Dialog UI -->
        <UI>
            <Dialog Id="ConfigDlg" Width="370" Height="270" Title="[ProductName] Setup">
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
                <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
                
                <Control Id="Title" Type="Text" X="15" Y="15" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Guardian Server Configuration" />
                <Control Id="Description" Type="Text" X="25" Y="30" Width="220" Height="15" Transparent="yes" NoPrefix="yes" Text="Please enter your Guardian server connection details." />
                
                <Control Id="ServerUrlLabel" Type="Text" X="20" Y="60" Width="330" Height="15" Text="&amp;Server WebSocket URL (e.g., ws://yourserver:5000/ws):" />
                <Control Id="ServerUrlEdit" Type="Edit" X="20" Y="75" Width="330" Height="18" Property="SERVER_URL" Indirect="no" />
                
                <Control Id="RegTokenLabel" Type="Text" X="20" Y="110" Width="330" Height="15" Text="&amp;Registration Token (Optional):" />
                <Control Id="RegTokenEdit" Type="Edit" X="20" Y="125" Width="330" Height="18" Property="REGISTRATION_TOKEN" Indirect="no" />
                
                <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next">
                    <Publish Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
                </Control>
                <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back">
                    <Publish Event="NewDialog" Value="InstallDirDlg">1</Publish>
                </Control>
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
                    <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
                </Control>
            </Dialog>

            <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
            <UIRef Id="WixUI_InstallDir" />

            <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="ConfigDlg" Order="5">1</Publish>
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="ConfigDlg" Order="5">1</Publish>
        </UI>

        <Feature Id="ProductFeature" Title="TimeKpr Agent" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
        </Feature>
    </Product>

    <Fragment>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="TimeKpr" />
            </Directory>
        </Directory>
    </Fragment>

    <Fragment>
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="ProductComponent" Guid="a4b27670-3df1-4322-87eb-12df713f01ab">
                <File Id="TimeKprAgentEXE" Source="$(var.SourceDir)\timekpr-agent.exe" KeyPath="yes" />
                
                <!-- Install and configure the Windows Service -->
                <ServiceInstall
                    Id="ServiceInstaller"
                    Type="ownProcess"
                    Name="TimeKprAgent"
                    DisplayName="TimeKpr Agent Service"
                    Description="Parental Control Agent for TimeKpr"
                    Start="auto"
                    Account="LocalSystem"
                    ErrorControl="normal" />
                
                <!-- Control the Windows Service -->
                <ServiceControl
                    Id="ServiceControl"
                    Name="TimeKprAgent"
                    Start="install"
                    Stop="both"
                    Remove="uninstall"
                    Wait="yes" />
            </Component>
            
            <Component Id="UserAgentAutostart" Guid="b4b27670-3df1-4322-87eb-12df713f01ab">
                <!-- Registry key for startup of user-agent helper -->
                <RegistryValue
                    Root="HKLM"
                    Key="Software\Microsoft\Windows\CurrentVersion\Run"
                    Name="TimeKprUserAgent"
                    Type="string"
                    Value="&quot;[INSTALLFOLDER]timekpr-agent.exe&quot; --user-agent"
                    KeyPath="yes" />
            </Component>
        </ComponentGroup>
    </Fragment>
</Wix>
