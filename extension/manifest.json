{
  "manifest_version": 3,
  "name": "Guardian",
  "version": "1.0.1",
  "description": "Guardian browser extension.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/watch*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/watch*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}