{
  "manifest_version": 3,
  "name": "Guardian",
  "version": "0.0.0",
  "description": "Guardian browser extension.",
  "permissions": [
    "storage",
    "alarms",
    "nativeMessaging",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blockedv2.html"],
      "matches": ["<all_urls>"]
    }
  ]
}