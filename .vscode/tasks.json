{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Launch Browser",
            "type": "shell",
            "command": "start http://localhost:5000",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run TimeKpr WebUI (Local)",
            "type": "shell",
            "command": "python app.py",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Compile / Check Python Syntax",
            "type": "shell",
            "command": "python -m py_compile server/app.py server/src/*.py",
            "group": "test",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Bundle i18n for Server",
            "type": "shell",
            "command": "python scripts/i18n/manage.py bundle --target server",
            "group": "test",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Compose Up",
            "type": "shell",
            "command": "docker-compose up -d --build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Compose Down",
            "type": "shell",
            "command": "docker-compose down",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Bundle i18n for Android Agent",
            "type": "shell",
            "command": "python scripts/i18n/manage.py bundle --target android",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Build Native",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/android-native-build.sh",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false
            },
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Assemble Debug",
            "type": "shell",
            "command": "./gradlew assembleDebug",
            "options": {
                "cwd": "${workspaceFolder}/android-agent"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false
            },
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Install Debug",
            "type": "shell",
            "command": "./gradlew installDebug",
            "options": {
                "cwd": "${workspaceFolder}/android-agent"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false
            },
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Rebuild and Install Debug",
            "dependsOn": [
                "Android Agent: Build Native",
                "Bundle i18n for Android Agent",
                "Android Agent: Install Debug"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Launch",
            "type": "shell",
            "command": "adb shell am start -a android.intent.action.MAIN -c android.intent.category.LAUNCHER -n com.guardian.agent/.ui.MainActivity",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Uninstall",
            "type": "shell",
            "command": "adb uninstall com.guardian.agent",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Logcat",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/android-logcat.sh",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Install and Wait for Debugger",
            "dependsOn": [
                "Android Agent: Build Native",
                "Android Agent: Install and Wait for Debugger (run)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Android Agent: Install and Wait for Debugger (run)",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/android-debug-prepare.sh",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": []
        }
    ]
}
