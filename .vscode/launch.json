{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server/app.py",
            "cwd": "${workspaceFolder}/server",
            "console": "integratedTerminal",
            "preLaunchTask": "Bundle i18n for Server",
            "jinja": true,
            "justMyCode": true,
            "env": {
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1",
                "TZ": "UTC",
                "DATABASE_URL": "sqlite:///timekpr.db",
                "DEBUG": "1"
            }
        },
        {
            "name": "Python: Simple Agent",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server/debug_agent.py",
            "cwd": "${workspaceFolder}/server",
            "console": "integratedTerminal",
            "jinja": true,
            "justMyCode": true,
            "env": {
                "TZ": "UTC"
            },
            "args": [
                "--server-url",
                "ws://127.0.0.1:5000/ws",
                "--agent-version",
                "v0.0.0-dev"
            ]
        },
        {
            "name": "Rust: Agent",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/agent/target/debug/timekpr-agent",
            "cwd": "${workspaceFolder}/agent",
            "console": "integratedTerminal",
            "env": {
                "TZ": "UTC"
            },
            "args": [
                "--server-url",
                "ws://127.0.0.1:5000/ws",
                "--agent-version",
                "v0.0.0-dev"
            ]
        },
        {
            "name": "Android Agent: Debug",
            "type": "android",
            "request": "launch",
            "preLaunchTask": "Android Agent: Rebuild and Install Debug",
            "appSrcRoot": "${workspaceFolder}/android-agent/app/src/main",
            "apkFile": "${workspaceFolder}/android-agent/app/build/outputs/apk/debug/app-debug.apk",
            "adbPort": 5037,
            "pmInstallArgs": [
                "-r",
                "-t"
            ],
            "amStartArgs": [
                "-D",
                "-a",
                "android.intent.action.MAIN",
                "-c",
                "android.intent.category.LAUNCHER",
                "-n",
                "com.guardian.agent/.ui.MainActivity"
            ],
            "postLaunchPause": 1500,
            "trace": false
        },
        {
            "name": "Android Agent: Attach (Java/Kotlin)",
            "type": "java",
            "request": "attach",
            "hostName": "localhost",
            "port": 5035,
            "preLaunchTask": "Android Agent: Install and Wait for Debugger",
            "projectName": "app"
        }
    ],
    "compounds": [
        {
            "name": "Debug Server",
            "configurations": [
                "Python: Flask App",
                "Python: Simple Agent"
            ]
        }
    ]
}