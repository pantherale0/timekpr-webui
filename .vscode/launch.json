{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server/app.py",
            "cwd": "${workspaceFolder}/server",
            "console": "integratedTerminal",
            "preLaunchTask": "Bundle i18n for Server",
            "jinja": true,
            "justMyCode": true,
            "env": {
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1",
                "TZ": "UTC",
                "DATABASE_URL": "sqlite:///timekpr.db",
                "DEBUG": "1"
            }
        },
        {
            "name": "Python: Simple Agent",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server/debug_agent.py",
            "cwd": "${workspaceFolder}/server",
            "console": "integratedTerminal",
            "jinja": true,
            "justMyCode": true,
            "env": {
                "TZ": "UTC"
            },
            "args": [
                "--server-url",
                "ws://127.0.0.1:5000/ws",
                "--agent-version",
                "v0.0.0-dev"
            ]
        },
        {
            "name": "Rust: Agent",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/agent/target/debug/timekpr-agent",
            "cwd": "${workspaceFolder}/agent",
            "console": "integratedTerminal",
            "env": {
                "TZ": "UTC"
            },
            "args": [
                "--server-url",
                "ws://127.0.0.1:5000/ws",
                "--agent-version",
                "v0.0.0-dev"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Debug Server",
            "configurations": [
                "Python: Flask App",
                "Python: Simple Agent"
            ]
        }
    ]
}