{
  "age_brackets": {
    "under7": {
      "label": "Under 7",
      "profile_title": "Early Discoverer",
      "description": "Strict rest \u2014 gentle daily rhythms with curated browsing shields for the youngest explorers."
    },
    "8_12": {
      "label": "8\u201312",
      "profile_title": "Guided Explorer",
      "description": "Balanced flow \u2014 moderate weekday boundaries with active routine locks and family-friendly browsing."
    },
    "13_15": {
      "label": "13\u201315",
      "profile_title": "Digital Apprentice",
      "description": "Autonomy focus \u2014 expanded exploration with transparency alerts instead of blind blocks."
    },
    "16_plus": {
      "label": "16+",
      "profile_title": "Independent Guardian",
      "description": "Self-regulation \u2014 lighter network rules with optional Anti-Bypass Watching when needed."
    }
  },
  "maturity_levels": {
    "low": {
      "label": "Open Dialogue",
      "description": "Guardian allows software freedom, but surfaces meaningful moments on your home dashboard for parent-child conversations.",
      "parent_translation": "Guardian allows software execution freedom, but alerts your home dashboard if a hidden rule or schedule conflict is detected, providing an opportunity for active parent-child conversations."
    },
    "medium": {
      "label": "Balanced Watch",
      "description": "A middle path \u2014 Routine Locks stay active with Family Dialogue Settings when something needs your attention.",
      "parent_translation": "Guardian keeps Routine Locks in place and nudges you when browsing or app patterns shift, so you can coach rather than constantly police."
    },
    "high": {
      "label": "Assisted Steps",
      "description": "Guardian handles application control and command boundaries automatically so you do not have to troubleshoot sneaky exploits.",
      "parent_translation": "Guardian will handle application control and command boundaries automatically so you don't have to troubleshoot sneaky exploits."
    }
  },
